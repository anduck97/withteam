    "title": "Imprinted",
    "artist": "&TEAM",
    "verses": [
      {"text": "溶けた Ice cream",
        "translation": "녹아버린 Ice cream"},
      {"text": "聞き飽きた Music",
        "translation": "질리도록 들은 Music"},
      {"text": "変わっていくこの季節",
        "translation": "변해 가는 이 계절"},
      {"text": "君だけは変わらずに",
        "translation": "너만은 변하지 않고"},
      {"text": "僕を照らしていて",
        "translation": "나를 계속 비춰 줘"},
      {"text": "Ah あれこれなんだかんだ真ん中は",
        "translation": "Ah 이것저것 따져 봐도 핵심은"},
      {"text": "実のところは単純で",
        "translation": "사실 아주 단순해"},
      {"text": "溢れ出す",
        "translation": "흘러넘쳐"},
      {"text": "飾らないまま",
        "translation": "꾸미지 않은 채로"},
      {"text": "きっと本当の気持ちなんて",
        "translation": "분명 진짜 마음 같은 건"},
      {"text": "半分ほども伝わらない",
        "translation": "절반도 전해지지 않아"},
      {"text": "この胸開いてすべてを",
        "translation": "이 가슴을 열어서 전부"},
      {"text": "君に見せたいのに",
        "translation": "너에게 보여 주고 싶은데"},
      {"text": "一途なこの想いは",
        "translation": "한결같은 이 마음은"},
      {"text": "「僕だけを見てくれないか？」",
        "translation": "「나만 봐 주지 않을래?」"},
      {"text": "永遠に続く真夏のように",
        "translation": "영원히 계속되는 한여름처럼"},
      {"text": "何気ない一言で",
        "translation": "별것 아닌 한마디에"},
      {"text": "すぐに笑顔になる",
        "translation": "금방 웃게 돼"},
      {"text": "モノクロなその日々を",
        "translation": "흑백이던 그 나날을"},
      {"text": "彩る僕になるよ",
        "translation": "물들이는 내가 될게"},
      {"text": "優しく照らす日差し追うあの花のように",
        "translation": "부드럽게 비추는 햇살을 좇는 저 꽃처럼"},
      {"text": "君以外愛せないってそう刻まれているんだ",
        "translation": "너 말고는 사랑할 수 없다고 그렇게 새겨져 있어"},
